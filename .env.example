# Google Application Credentials (File path option)
GOOGLE_APPLICATION_CREDENTIALS=./kunci_rahasia_google.json

# Or raw JSON credentials string option (Highly recommended for production/VPS to avoid file uploads)
# GOOGLE_CREDENTIALS='{"type": "service_account", "project_id": "...", ...}'

# Application Environment
NODE_ENV=development

# Database Configuration
# Path to SQLite database file (relative to project root)
DATABASE_PATH=./data/projects.db

# Google Sheets Configuration (Required for webhook sync)
# Get these from your Google Sheets URL:
# https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit#gid={SHEET_ID}
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_ID=your_sheet_id_here

# Optional: API Key for external services
# API_KEY=your_api_key_here

# Optional: enable background sync scheduler and Socket.IO in local dev
# Use `npm run dev:services` instead of setting these manually for local development.
ENABLE_BACKGROUND_SERVICES=false
NEXT_PUBLIC_ENABLE_WEBSOCKET=false
# NEXT_PUBLIC_WS_URL=http://localhost:3001

# Optional: Public URL of the application
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp Alert via WAHA (push alerting for at-risk projects)
# Set WAHA_ALERT_ENABLED=true to activate. Alert runs daily at 08:00.
# Requires ENABLE_BACKGROUND_SERVICES=true to run on server startup.
WAHA_ALERT_ENABLED=false
WAHA_URL=https://your-waha-instance.example.com
WAHA_SESSION=your_session_name
WAHA_API_KEY=your_api_key_here
# Comma-separated WhatsApp Group IDs (e.g. 120363142428170648@g.us)
WAHA_GROUP_IDS=